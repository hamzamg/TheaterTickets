{
    "name": "theater/tickets",
    "type": "project",
    "description": "The Laravel Framework - Theater Tickets Management System",
    "keywords": ["framework", "laravel", "theater", "tickets"],
    "license": "MIT",
    "require": {
        "php": "^8.5",
        "guzzlehttp/guzzle": "^7.10",
        "laravel/framework": "^12.0",
        "laravel/jetstream": "^5.0",
        "laravel/sanctum": "^4.3",
        "laravel/tinker": "^2.11",
        "livewire/livewire": "^4.0"
    },
    "require-dev": {
        "barryvdh/laravel-debugbar": "^4.0",
        "fakerphp/faker": "^1.24",
        "laravel-lang/common": "^6.7",
        "laravel/pint": "^1.18",
        "orchestra/testbench": "^10.9",
        "phpunit/phpunit": "^11.0",
        "spatie/laravel-ignition": "^2.11"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        },
        "audit": {
            "block-insecure": false
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
